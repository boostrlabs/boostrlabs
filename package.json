{
  "name": "boostr-labs-website",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/patch-johankarrd-v60.mjs",
    "preview": "preview --host 127.0.0.1",
    "deploy:check": "npm run build",
    "smoke:launch": "node scripts/launch-smoke-test.mjs",
    "ecosystem:dev": "pnpm --filter @boostr/ecosystem dev",
    "ecosystem:build": "pnpm --filter @boostr/ecosystem build",
    "ecosystem:lint": "pnpm --filter @boostr/ecosystem lint",
    "ecosystem:typecheck": "pnpm --filter @boostr/ecosystem typecheck"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  }
}
